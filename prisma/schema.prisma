generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?  @unique
  password      String
  role          Role     @default(USER)
  referralCode  String   @unique
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  balance       Float    @default(0)
  totalEarnings Float    @default(0)
  totalInvested Float    @default(0)
  isActive      Boolean  @default(true)
  isSuspended   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  level        Int      @default(1)
  xp           Float    @default(0)
  isVerified   Boolean  @default(false)
  spinLastUsed DateTime?
  lastActive   DateTime?

  passes        UserPass[]
  transactions  Transaction[]
  tasks         UserTask[]
  withdrawals   Withdrawal[]
  affiliateClicks AffiliateClick[]
  notifications Notification[]
  resetTokens   PasswordResetToken[]
  userMissions  UserMission[]
  teamMember    TeamMember?
  ledTeams      Team[]           @relation("TeamLeader")
  spinResults   SpinResult[]
  leaderboardEntry LeaderboardEntry?
  teamJoinRequests TeamJoinRequest[]
  giftClaims    GiftClaim[]

  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

model Pass {
  id          String   @id @default(cuid())
  name        String
  price       Float
  dailyReturn Float
  duration    Int
  description String?
  isActive    Boolean  @default(true)
  color       String   @default("#3b6fd4")
  icon        String   @default("star")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userPasses  UserPass[]

  @@map("passes")
}

model UserPass {
  id          String     @id @default(cuid())
  userId      String
  passId      String
  user        User       @relation(fields: [userId], references: [id])
  pass        Pass       @relation(fields: [passId], references: [id])
  status      PassStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  amountPaid  Float
  totalEarned Float      @default(0)
  paymentRef  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("user_passes")
}

enum PassStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  description String
  status      TransactionStatus @default(PENDING)
  reference   String?           @unique
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("transactions")
}

enum TransactionType {
  PASS_PURCHASE
  DAILY_EARNING
  TASK_REWARD
  AFFILIATE_COMMISSION
  WITHDRAWAL
  REFERRAL_BONUS
  DEPOSIT
  VERIFICATION
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

model DailyTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  reward      Float
  type        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userTasks   UserTask[]

  @@map("daily_tasks")
}

model UserTask {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  user        User      @relation(fields: [userId], references: [id])
  task        DailyTask @relation(fields: [taskId], references: [id])
  completedAt DateTime  @default(now())
  reward      Float

  @@unique([userId, taskId, completedAt])
  @@map("user_tasks")
}

model Withdrawal {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  amount      Float
  method      String
  accountInfo String
  status      WithdrawalStatus   @default(PENDING)
  processedAt DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("withdrawals")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  passId      String
  amount      Float
  provider    String
  reference   String        @unique
  status      PaymentStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

model AffiliateClick {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("affiliate_clicks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Mission {
  id            String   @id @default(cuid())
  title         String
  titleEn       String?
  description   String?
  descriptionEn String?
  type          String   // invest, invite, task, daily, weekly
  target        Float
  reward        Float
  rewardType    String   @default("money")
  isActive      Boolean  @default(true)
  period        String   @default("all_time")
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  userMissions  UserMission[]
  @@map("missions")
}

model UserMission {
  id          String   @id @default(cuid())
  userId      String
  missionId   String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  progress    Float    @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  @@unique([userId, missionId])
  @@map("user_missions")
}

model Team {
  id            String       @id @default(cuid())
  name          String       @unique
  leaderId      String
  leader        User         @relation("TeamLeader", fields: [leaderId], references: [id])
  members       TeamMember[]
  joinRequests  TeamJoinRequest[]
  totalInvested Float        @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  @@map("teams")
}

model TeamJoinRequest {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  phone     String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  @@unique([teamId, userId])
  @@map("team_join_requests")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())
  @@map("team_members")
}

model SpinConfig {
  id          String  @id @default(cuid())
  label       String
  value       Float   @default(0)
  type        String  @default("money")
  probability Float   @default(0.1)
  color       String  @default("#3b6fd4")
  isActive    Boolean @default(true)
  @@map("spin_configs")
}

model SpinResult {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  value     Float
  type      String
  createdAt DateTime @default(now())
  @@map("spin_results")
}

model Event {
  id            String    @id @default(cuid())
  title         String
  titleEn       String?
  description   String?
  descriptionEn String?
  type          String    @default("bonus")
  value         Float     @default(0)
  isActive      Boolean   @default(true)
  showBanner    Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
  @@map("events")
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Float    @default(0)
  rank      Int?
  period    String   @default("all_time")
  updatedAt DateTime @updatedAt
  @@map("leaderboard_entries")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  adminRole  String   @default("ADMIN")
  action     String
  target     String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@map("admin_logs")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Settings {
  key   String @id
  value String

  @@map("settings")
}

model GiftCode {
  id          String      @id @default(cuid())
  code        String      @unique
  description String?
  value       Float       @default(0)
  maxWinners  Int         @default(3)
  isActive    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  claims      GiftClaim[]
  @@map("gift_codes")
}

model GiftClaim {
  id        String   @id @default(cuid())
  codeId    String
  giftCode  GiftCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimedAt DateTime @default(now())
  @@unique([codeId, userId])
  @@map("gift_claims")
}
