# ============================================
# AUREVIA — payment-service (Railway)
# Variables a definir dans Railway → Variables
# ============================================

# Jeton partage avec le front Aurevia (Vercel). DOIT etre identique a la valeur
# PAYMENT_SERVICE_TOKEN cote Vercel. Genere : openssl rand -base64 32
PAYMENT_SERVICE_TOKEN=

# Cles marchandes GeniusPay (live). Elles ne vivent QUE sur ce service.
GENIUSPAY_API_KEY=pk_live_xxxxxxxxxxxxxxxx
GENIUSPAY_SECRET=sk_live_xxxxxxxxxxxxxxxx

# Optionnel — l'URL de l'API marchande est figee par defaut. Ne la changer que
# si GeniusPay communique un nouveau chemin /api/vN/merchant.
GENIUSPAY_BASE_URL=https://geniuspay.ci/api/v1/merchant

# PORT est fourni automatiquement par Railway, ne pas definir manuellement.
