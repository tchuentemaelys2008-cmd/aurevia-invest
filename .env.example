# ============================================
# AUREVIA INVEST — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ── Database (PostgreSQL) ─────────────────────
# Local: postgresql://user:password@localhost:5432/aurevia_invest
# Railway: copy from Railway dashboard → Variables
DATABASE_URL="postgresql://user:password@localhost:5432/aurevia_invest"

# ── Authentication ────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── App URL ───────────────────────────────────
# Vercel: your production URL (e.g. https://aurevia-invest.vercel.app)
NEXT_PUBLIC_URL="http://localhost:3000"

# ── FAPSHI Payment (Cameroon Mobile Money) ───
# Dashboard: https://fapshi.com/dashboard
FAPSHI_USER="your-fapshi-api-user"
FAPSHI_KEY="your-fapshi-api-key"
FAPSHI_BASE_URL="https://live.fapshi.com"

# ── GeniusPay (Orange Money, MTN, Wave, Carte) ─
# Dashboard: https://geniuspay.ci → Paramètres → API
# Sandbox keys start with pk_sandbox_ / sk_sandbox_
# Live keys start with pk_live_ / sk_live_
GENIUSPAY_API_KEY="pk_sandbox_xxxxxxxxxxxxxxxx"
GENIUSPAY_SECRET="sk_sandbox_xxxxxxxxxxxxxxxx"
GENIUSPAY_BASE_URL="https://geniuspay.ci/api/v1/merchant"
# Webhook secret (returned once at webhook creation — store securely)
# Format: whsec_sandbox_... or whsec_live_...
# Webhook URL to configure on GeniusPay → Webhooks:
#   <NEXT_PUBLIC_URL>/api/payments/geniuspay/webhook
# Events: payment.success, payment.failed, payment.cancelled, payment.expired
GENIUSPAY_WEBHOOK_SECRET="whsec_sandbox_xxxxxxxxxxxxxxxx"

# ── Cron Secret (for daily earnings job) ─────
# Generate: openssl rand -base64 32
# Add same value to Vercel → Settings → Cron Job Secret
CRON_SECRET="your-cron-secret-key"

# ── Email (Optional — for notifications) ─────
# Resend: https://resend.com
RESEND_API_KEY="re_your_resend_key"
EMAIL_FROM="noreply@aurevia-invest.com"

# ── Node Environment ──────────────────────────
NODE_ENV="development"

# ── Google OAuth (Sign in with Google) ──
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <YOUR_ORIGIN>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
